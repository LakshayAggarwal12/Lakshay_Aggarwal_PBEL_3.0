# Copy this file to .env and fill in real values before running

# SQLite for local dev — no setup required
# DATABASE_URL=sqlite:///./resume_screener.db

# Postgres for production (e.g. Render's managed Postgres). Paste the
# connection string your provider gives you as-is — both 'postgres://' and
# 'postgresql://' schemes work, the app normalizes this automatically.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# CORS - comma separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Upload constraints
MAX_UPLOAD_SIZE_MB=5
ALLOWED_EXTENSIONS=.pdf,.docx

APP_ENV=development
