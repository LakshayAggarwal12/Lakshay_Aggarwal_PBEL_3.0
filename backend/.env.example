# Copy this file to .env and fill in real values before running

# SQLite for local dev — swap for a Postgres URL in production
# e.g. postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./resume_screener.db

# CORS - comma separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Upload constraints
MAX_UPLOAD_SIZE_MB=5
ALLOWED_EXTENSIONS=.pdf,.docx

APP_ENV=development
